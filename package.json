{
  "name": "local-addon-siteground-deploy",
  "productName": "SiteGround Deploy",
  "version": "1.0.0",
  "author": "ZDM Designs",
  "description": "Deploy Local WordPress sites to SiteGround via SSH.",
  "keywords": [
    "local-addon"
  ],
  "slug": "siteground-deploy",
  "bgColor": "#EF5B25",
  "icon": "icon.svg",
  "main": "lib/main.js",
  "renderer": "lib/renderer.js",
  "license": "MIT",
  "files": [
    "lib",
    "icon.svg"
  ],
  "engines": {
    "local-by-flywheel": ">=6.5.2"
  },
  "scripts": {
    "build":          "webpack --config webpack.config.js",
    "build:prod":     "webpack --config webpack.config.js --env mode=production",
    "watch":          "webpack --config webpack.config.js --watch",
    "build:main":     "webpack --config webpack.config.js --env target=main",
    "build:renderer": "webpack --config webpack.config.js --env target=renderer",
    "clean":          "node -e \"require('fs').rmSync('lib',{recursive:true,force:true});require('fs').mkdirSync('lib',{recursive:true})\"",
    "prepack":        "npm run build:prod"
  },
  "peerDependencies": {
    "react": ">=16.4.0",
    "react-dom": ">=16.4.0",
    "react-router-dom": "^5.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "node-forge": "^1.3.1",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^10.0.3",
    "archiver": "^6.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0",
    "css-loader": "^6.10.0",
    "style-loader": "^3.3.4",
    "@getflywheel/local": "^9"
  },
  "bundledDependencies": [
    "electron-store",
    "node-forge",
    "ssh2",
    "ssh2-sftp-client",
    "archiver",
    "uuid"
  ]
}
